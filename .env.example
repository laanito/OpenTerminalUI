# Copy this file to .env for Docker Compose runtime.
# Never put real secrets in git-tracked files.

FMP_API_KEY=your_fmp_api_key
FINNHUB_API_KEY=your_finnhub_api_key
# CoinGecko powers the crypto market data (markets, dominance, etc.). The keyless
# public API works out of the box; set a free demo key to raise rate limits.
COINGECKO_API_KEY=
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_FEED=iex
ALPACA_ADJUSTMENT=raw
FINNHUB_WS_ENABLED=true
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=optional_daily_access_token
REDIS_URL=

# OpenAI-compatible LLM endpoint for news sentiment, emotion & insights.
# Defaults to a local Ollama server; also works with LM Studio, OpenAI,
# OpenRouter, etc. LLM_API_KEY is only needed for hosted providers.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=
LLM_ENABLED=true
# Legacy aliases (still honored): LM_STUDIO_BASE_URL / LM_STUDIO_MODEL / LM_STUDIO_ENABLED

# --- Database ---------------------------------------------------------------
# Docker Compose defaults to PostgreSQL (service "postgres"). The backend
# converts this URL to the async (asyncpg) / sync (psycopg) drivers as needed.
# To use SQLite instead, set:
#   DATABASE_URL=sqlite+aiosqlite:////data/openterminal.db
DATABASE_URL=postgresql://openterminalui:openterminalui@postgres:5432/openterminalui
POSTGRES_DB=openterminalui
POSTGRES_USER=openterminalui
POSTGRES_PASSWORD=openterminalui
# Host port the postgres container is published on (change if 5432 is in use).
POSTGRES_PORT=5432
# Host port the app is published on (change if 8000 is in use).
APP_PORT=8000

OPENTERMINALUI_PREFETCH_ENABLED=0
OPENTERMINALUI_SQLITE_URL=sqlite:////data/openterminalui.db
# Comma-separated list. Example:
# OPENTERMINALUI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENTERMINALUI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CHART_CACHE_TTL=900
OHLCV_HOT_TTL_SECONDS=300
OHLCV_WARM_TTL_SECONDS=86400
OHLCV_COLD_ROOT=data/bars

# SMTP — optional. Only needed to actually deliver scheduled reports by email.
# Without these, scheduled reports are still created/listed and on-demand report
# generation/download works; only the scheduled email delivery is skipped.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=reports@example.com
# SMTP_PASSWORD=your_smtp_password
