# Copy this file to backend/.env and replace with your own credentials.
# Never commit real credentials.

FMP_API_KEY=your_fmp_api_key
FINNHUB_API_KEY=your_finnhub_api_key
FRED_API_KEY=your_fred_api_key_here
FMP_API_KEY=your_fmp_api_key

# AI / LLM Configuration
# The terminal talks to any OpenAI-compatible chat endpoint, so the same config
# works with Ollama (default), LM Studio, OpenAI, OpenRouter, Groq, vLLM, etc.
# Point LLM_BASE_URL / LLM_MODEL at your provider; LLM_API_KEY is only needed for
# hosted providers (local servers like Ollama/LM Studio ignore it).
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=
LLM_ENABLED=true
# auto | json_schema | json | none — how to request JSON from the provider.
LLM_STRUCTURED_OUTPUT=auto

# Private "second brain" RAG embeddings (same OpenAI-compatible endpoint).
# With Ollama: `ollama pull nomic-embed-text` once. BRAIN_EMBED_FALLBACK uses a
# local sentence-transformers model (requirements-ml.txt) if the endpoint has no
# /embeddings route.
LLM_EMBED_MODEL=nomic-embed-text
BRAIN_EMBED_DIM=768
BRAIN_EMBED_FALLBACK=true

# Examples for other providers:
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1    LLM_MODEL=gpt-4o-mini    LLM_API_KEY=sk-...
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1 LLM_MODEL=meta-llama/llama-3.1-8b-instruct LLM_API_KEY=...
#   LM Studio:  LLM_BASE_URL=http://localhost:1234/v1     LLM_MODEL=<loaded-model>

# Legacy aliases (still honored): LM_STUDIO_BASE_URL / LM_STUDIO_MODEL / OPENAI_API_KEY / OLLAMA_BASE_URL
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=optional_daily_access_token

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_QUOTE_CHANNELS_TTL=300
REDIS_MAX_CONNECTIONS=50

# Optional runtime overrides
# OPENTERMINALUI_SQLITE_URL=sqlite:///./backend/openterminalui.db
# OPENTERMINALUI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# OPENTERMINALUI_PREFETCH_ENABLED=0
